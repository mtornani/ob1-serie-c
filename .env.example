# OB1 Serie C - Environment Variables
# Copia in .env e compila con i valori reali. Non committare .env.

# === SCRAPING / AI ===

# Tavily API key (scraping primario — Ouroboros pipeline)
TAVILY_API_KEY=your_tavily_key_here

# Serper.dev API key (fallback scraping)
SERPER_API_KEY=your_serper_key_here

# Google Gemini API key (enrichment + discovery grounding)
GEMINI_API_KEY=your_gemini_key_here

# Fallback LLM quando Gemini free tier (20 RPD) esaurito — pick one
# Groq free: https://console.groq.com
GROQ_API_KEY=
# oppure OpenRouter free models
OPENROUTER_API_KEY=

# Budget discovery Gemini per run (lascia RPD all'enrich)
# GEMINI_DISCOVERY_BUDGET=4
# MAX_ENRICH_BATCHES=4

# === TELEGRAM ===

# Bot token (unico per tutti i canali)
# Crea il bot: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_telegram_token_here

# Chat ID privato Mirko — notifiche pipeline success
# Ottieni con: https://t.me/userinfobot
TELEGRAM_CHAT_ID=1465485090

# Canale pubblico @ob1scout — alert HOT pubblici
TELEGRAM_PUBLIC_CHANNEL_ID=@ob1scout

# Canale admin privato — alert errori pipeline (NUOVO — Fix 2/3)
# Crea un gruppo privato o usa il tuo chat ID personale
TELEGRAM_OFFICE_CHAT_ID=your_office_chat_id_here

# === CLOUD DEPLOY (GitHub Actions) ===
# Settings → Secrets → Actions → New repository secret
#
# Secrets da configurare:
#   TAVILY_API_KEY           ← scraping primario
#   SERPER_API_KEY           ← fallback scraping
#   GEMINI_API_KEY           ← AI enrichment
#   TELEGRAM_BOT_TOKEN       ← bot token unico
#   TELEGRAM_CHAT_ID         ← chat ID notifiche success
#   TELEGRAM_PUBLIC_CHANNEL_ID ← canale @ob1scout
#   TELEGRAM_OFFICE_CHAT_ID  ← ⚠️ NUOVO: alert errori pipeline
